# Public site origin, without a trailing slash
NEXT_PUBLIC_SITE_URL=https://formaltype.app

# Product analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Beta feedback form URL; falls back to feedback@formaltype.app
NEXT_PUBLIC_FEEDBACK_URL=

# Google AdSense (optional; ad areas stay hidden until configured)
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_BANNER_SLOT=
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=

# Existing Supabase connection
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
